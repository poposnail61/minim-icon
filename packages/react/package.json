{
  "name": "@minim-icon/react",
  "version": "0.1.0",
  "description": "React components for the Minim Icon SVG collection.",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./icons/*": {
      "types": "./dist/types/icons/*.d.ts",
      "import": "./dist/esm/icons/*.js",
      "require": "./dist/cjs/icons/*.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "scripts": {
    "generate": "node scripts/generate-icons.mjs",
    "check:generated": "node scripts/generate-icons.mjs --check",
    "build": "npm run generate && npm run clean:dist && tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && tsc -p tsconfig.types.json && node scripts/write-cjs-package-json.mjs",
    "clean:dist": "node scripts/clean-dist.mjs",
    "typecheck": "tsc -p tsconfig.esm.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vitest": "^1.6.1"
  }
}
